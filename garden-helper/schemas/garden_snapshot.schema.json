{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://garden-helper.local/schemas/garden_snapshot.schema.json",
  "title": "Garden Snapshot",
  "type": "object",
  "required": [
    "garden",
    "beds",
    "obstacles",
    "plant_catalog",
    "plantings",
    "observations",
    "sync_metadata"
  ],
  "properties": {
    "garden": {
      "type": "object",
      "required": ["width", "height"],
      "properties": {
        "width": { "type": "number" },
        "height": { "type": "number" }
      },
      "additionalProperties": true
    },
    "beds": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["bed_id", "name", "x", "y", "w", "h", "type", "notes"],
        "properties": {
          "bed_id": { "type": "string", "minLength": 1 },
          "name": { "type": "string" },
          "x": { "type": "number" },
          "y": { "type": "number" },
          "w": { "type": "number" },
          "h": { "type": "number" },
          "type": { "type": "string" },
          "notes": { "type": "string" },
          "metadata": { "type": "object" }
        },
        "additionalProperties": true
      }
    },
    "obstacles": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["obstacle_id", "name", "x", "y", "w", "h", "type", "notes"],
        "properties": {
          "obstacle_id": { "type": "string", "minLength": 1 },
          "name": { "type": "string" },
          "x": { "type": "number" },
          "y": { "type": "number" },
          "w": { "type": "number" },
          "h": { "type": "number" },
          "type": { "type": "string" },
          "notes": { "type": "string" },
          "metadata": { "type": "object" }
        },
        "additionalProperties": true
      }
    },
    "plant_catalog": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["plant_id", "display_name", "source"],
        "properties": {
          "plant_id": { "type": "string", "minLength": 1 },
          "display_name": { "type": "string", "minLength": 1 },
          "type": { "type": ["string", "null"] },
          "cultivar": { "type": ["string", "null"] },
          "species": { "type": ["string", "null"] },
          "source": { "type": ["string", "null"] },
          "metadata": { "type": "object" }
        },
        "additionalProperties": true
      }
    },
    "plantings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["planting_id", "bed_id", "plant_id", "quantity", "grid_cells", "status", "notes"],
        "properties": {
          "planting_id": { "type": "string", "minLength": 1 },
          "bed_id": { "type": "string", "minLength": 1 },
          "plant_id": { "type": "string", "minLength": 1 },
          "quantity": { "type": "integer", "minimum": 1 },
          "grid_cells": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["row", "col"],
              "properties": {
                "row": { "type": "integer", "minimum": 0 },
                "col": { "type": "integer", "minimum": 0 }
              },
              "additionalProperties": false
            }
          },
          "date_planted": { "type": ["string", "null"] },
          "status": { "type": "string" },
          "notes": { "type": "string" },
          "metadata": { "type": "object" }
        },
        "additionalProperties": true
      }
    },
    "observations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["observation_id", "timestamp", "kind", "description"],
        "properties": {
          "observation_id": { "type": "string", "minLength": 1 },
          "timestamp": { "type": "string", "minLength": 1 },
          "kind": { "type": "string" },
          "description": { "type": "string" },
          "photo_ref": { "type": ["string", "null"] },
          "bed_id": { "type": ["string", "null"] },
          "planting_id": { "type": ["string", "null"] },
          "metadata": { "type": "object" }
        },
        "anyOf": [
          { "required": ["bed_id"] },
          { "required": ["planting_id"] }
        ],
        "additionalProperties": true
      }
    },
    "sync_metadata": {
      "type": "object",
      "required": ["snapshot_id", "exported_at", "source_app_version"],
      "properties": {
        "snapshot_id": { "type": "string", "minLength": 1 },
        "exported_at": { "type": "string", "minLength": 1 },
        "source_app_version": { "type": "string", "minLength": 1 },
        "metadata": { "type": "object" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
